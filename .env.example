# Copy to .env.local for local development, or set these in Vercel → Project → Settings → Environment Variables for production.

# Required for storyboard and character generation (Claude)
ANTHROPIC_API_KEY=

# Optional: for image generation via Gemini. Get a key from https://aistudio.google.com/apikey
# If not set, the app can still use Pollinations for images (no key required).
GEMINI_API_KEY=
# Alternative env name some Google tools use:
# GOOGLE_API_KEY=
